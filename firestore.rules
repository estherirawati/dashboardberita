rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net - deny all by default
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    // Validation Schemas
    function isValidPost(data) {
      return data.keys().hasAll(['id', 'caption', 'likes', 'comments', 'category', 'publishedAt', 'statusEvaluasi'])
             && data.id is string && data.id.size() <= 128
             && data.caption is string && data.caption.size() <= 10000
             && data.likes is int
             && data.comments is int
             && data.category is string && data.category.size() <= 100
             && data.publishedAt is string && data.publishedAt.size() <= 100
             && data.statusEvaluasi is string && data.statusEvaluasi.size() <= 50;
    }
    
    function isValidNote(data) {
      return data.keys().hasAll(['id', 'postId', 'userId', 'username', 'content', 'createdAt'])
             && data.id is string && data.id.size() <= 128
             && data.postId is string && data.postId.size() <= 128
             && data.userId is string && data.userId == request.auth.uid
             && data.username is string && data.username.size() <= 155
             && data.content is string && data.content.size() <= 5000;
    }
    
    function isValidAnnouncement(data) {
      return data.keys().hasAll(['id', 'userId', 'username', 'title', 'content', 'createdAt'])
             && data.id is string && data.id.size() <= 128
             && data.userId is string && data.userId == request.auth.uid
             && data.username is string && data.username.size() <= 155
             && data.title is string && data.title.size() <= 250
             && data.content is string && data.content.size() <= 10000;
    }
    
    // Rules matching
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(postId) && isValidPost(incoming());
      // Logged in editors can update posts (metrics, verification, evaluative status updates)
      allow update: if isSignedIn() && isValidPost(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasAny(['statusEvaluasi', 'verified', 'likes', 'comments', 'views', 'engagementRate', 'isViral', 'updatedAt'])
      );
      allow delete: if false; // No deletion of news archives
      
      match /notes/{noteId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isValidId(noteId) && isValidNote(incoming());
        allow update: if isSignedIn() && isValidNote(incoming()) && existing().userId == request.auth.uid;
        allow delete: if isSignedIn() && existing().userId == request.auth.uid;
      }
    }
    
    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(announcementId) && isValidAnnouncement(incoming());
      allow update: if isSignedIn() && isValidAnnouncement(incoming()) && existing().userId == request.auth.uid;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
